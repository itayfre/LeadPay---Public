# Database — for LOCAL DEV ONLY, point DATABASE_URL at the dev Supabase project
# (leadpay-dev, ref `your-project-ref`). Production DATABASE_URL lives only
# in Railway env vars, never in this file.
# pytest enforces this via a guard in backend/tests/conftest.py that refuses to
# run if DATABASE_URL points at the prod project ref.
#
# Pick ONE of the two URI formats below for DATABASE_URL:
#
# 1) Session Pooler (recommended on IPv4-only networks):
# DATABASE_URL=postgresql://postgres.your-project-ref:<PASSWORD>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# 2) Direct connection (works only if your network supports IPv6):
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.your-project-ref.supabase.co:5432/postgres
# App Settings
APP_ENV=development
APP_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
DEBUG=false

# CORS (comma-separated frontend URLs)
FRONTEND_URL=http://localhost:5173

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
